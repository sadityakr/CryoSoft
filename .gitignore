# ── Whitelist approach: ignore everything, then carve out tracked items ──

# Ignore all files and folders at the root
/*
/.*

# Always track these files
!/.gitignore
!/pyproject.toml
!/requirements.txt
!/README.md
!/LICENSE

# Tracked folders
!/cryosoft/
!/data/
!/tests/

# Exclude compiled Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo

# Exclude log files (keep directory placeholder)
cryosoft/logs/*.log
cryosoft/logs/*.log.*

# Exclude real experiment data; only sample files are tracked
data/*.h5
!data/sample_*.h5
