# ── Whitelist approach: ignore everything, then carve out tracked items ──

# Ignore all files and folders at the root
/*
/.*

# Always track these files
!/.gitignore
!/pyproject.toml
!/requirements.txt
!/README.md
!/LICENSE
!/Makefile
!/GLOSSARY.md

# CI configuration (GitHub Actions now; .gitlab-ci.yml is ready for the GitLab migration)
!/.github/
!/.gitlab-ci.yml

# Tracked folders
!/cryosoft/
!/data/
!/tests/

# Claude Code project skills/agents are tracked (git history is the safety net);
# the rest of .claude/ (local settings) stays untracked — this repo is public.
!/.claude/
/.claude/*
!/.claude/skills/
!/.claude/agents/

# Exclude compiled Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo

# Exclude log files (keep directory placeholder)
cryosoft/logs/*.log
cryosoft/logs/*.log.*

# Exclude real experiment data; only sample files are tracked
data/*.h5
!data/sample_*.h5
